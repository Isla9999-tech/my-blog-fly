---
import type { Language, PostHeading } from '@src/types';
import { theme } from '../theme';
import { is_post } from '@src/utils';
const isPost = is_post(Astro.url);
import Head from './head.astro';
import HeaderIndex from './header/index.astro';
import Footer from './footer.astro';
import Sidebar from './sidebar.astro';
import LoadingIndex from './loadings/index.astro';
import WidgetIndex from './widget/index.astro';
import AdditionalJs from './additional-js.astro';
import Rightside from './rightside.astro';
import Search from '../components/Search.astro';

interface Props {
  lang: Language;
  page: Record<string, any>;
  postHeadings?: PostHeading[];
}
const { lang, page, postHeadings } = Astro.props;
const asideClass = theme.aside.enable && theme.aside.hide ? 'hide-aside' : '';

const excludeFromSearch = page.type === 'archives' || page.type === 'index';
---
<html lang={lang} class={asideClass}>
  <Head lang={lang} page={page}/>
  <body>
    <LoadingIndex />
    <Sidebar lang={lang}/>
    <div id="body-wrap" class={isPost ? 'post' : 'page' + (page.type ? ' type-' + page.type : '')}>
      <HeaderIndex lang={lang} page={page}/>

      <main class='layout flex justify-between pt-5 pb-8 max-[900px]:flex-col' id="content-inner" data-pagefind-ignore={excludeFromSearch ? '' : undefined}>
        <slot />
        <WidgetIndex lang={lang} postHeadings={postHeadings}/>
      </main>

      <Footer lang={lang}/>
    </div>
    <Rightside lang={lang}/>
    <AdditionalJs />
    <Search lang={lang} />
  </body>
</html>
