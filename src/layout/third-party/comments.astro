---
import type { Language } from '@src/types';
import { useTranslations } from '@src/utils';

interface Props { lang: Language; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<hr class="custom-hr" />
<div id="post-comment">
  <div class="comment-head">
    <div class="comment-headline">
      <i class="fas fa-comments fa-fw"></i>
      <span>{' ' + t('comment')}</span>
    </div>
  </div>

  <div class="comment-wrap">
    <div id="comment-form" class="comment-form">
      <div class="comment-form-row comment-form-names">
        <input type="text" id="comment-nickname" placeholder="昵称 *" maxlength="50" />
        <input type="email" id="comment-email" placeholder="邮箱（选填，不会公开）" maxlength="100" />
      </div>
      <div class="comment-form-row">
        <textarea id="comment-content" placeholder="说点什么...（Ctrl+Enter 发送）" maxlength="2000" rows="4"></textarea>
      </div>
      <div class="comment-form-row">
        <button id="comment-submit" class="comment-submit-btn">发表评论</button>
        <span id="comment-status" class="comment-status"></span>
      </div>
    </div>
    <div id="comment-list" class="comment-list">
      <div class="comment-loading">加载中...</div>
    </div>
  </div>
</div>

<style>
  .comment-form { margin-bottom: 24px; }
  .comment-form-row { margin-bottom: 12px; }
  .comment-form-names { display: flex; gap: 12px; }
  .comment-form-names input { flex: 1; }
  .comment-form input,
  .comment-form textarea {
    width: 100%; padding: 10px 14px;
    border: 1px solid var(--light-grey, #eee); border-radius: 8px;
    font-size: 14px; background: var(--card-bg, #fff);
    color: var(--font-color, #333); outline: none;
    transition: border-color 0.2s; font-family: inherit;
  }
  .comment-form input:focus,
  .comment-form textarea:focus { border-color: #49b1f5; }
  .comment-form textarea { resize: vertical; min-height: 80px; line-height: 1.6; }
  .comment-submit-btn {
    padding: 8px 24px; background: #49b1f5; color: #fff;
    border: none; border-radius: 8px; font-size: 14px;
    cursor: pointer; transition: background 0.2s;
  }
  .comment-submit-btn:hover { background: #3a9de0; }
  .comment-submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .comment-status { margin-left: 12px; font-size: 13px; }
  .comment-list { margin-top: 8px; }
  .comment-loading, .comment-empty {
    color: #999; font-size: 14px; padding: 12px 0; text-align: center;
  }
  .comment-item {
    padding: 16px 0; border-bottom: 1px solid var(--light-grey, #eee);
  }
  .comment-item:last-child { border-bottom: none; }
  .comment-item-header {
    display: flex; align-items: center; gap: 8px; margin-bottom: 8px;
  }
  .comment-avatar {
    width: 32px; height: 32px; border-radius: 50%;
    background: #49b1f5; color: #fff;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 600; flex-shrink: 0;
  }
  .comment-nickname {
    font-weight: 600; font-size: 14px;
    color: var(--text-highlight-color, #333);
  }
  .comment-badge {
    font-size: 11px; padding: 1px 6px; border-radius: 4px;
    background: #49b1f5; color: #fff;
  }
  .comment-time { font-size: 12px; color: #999; }
  .comment-body {
    font-size: 14px; line-height: 1.8;
    color: var(--font-color, #555);
    white-space: pre-wrap; word-break: break-word;
  }
  @media (max-width: 600px) {
    .comment-form-names { flex-direction: column; gap: 12px; }
  }
</style>

<script>
  const slug = window.location.pathname;

  // Browser fingerprint: generate a stable ID per browser
  function getBrowserId(): string {
    let id = localStorage.getItem('comment_browser_id');
    if (id) return id;
    const nav = navigator as any;
    const screen = window.screen;
    const raw = [
      nav.userAgent, nav.language, screen.width, screen.height,
      screen.colorDepth, new Date().getTimezoneOffset()
    ].join('|');
    // Simple hash
    let hash = 0;
    for (let i = 0; i < raw.length; i++) {
      const chr = raw.charCodeAt(i);
      hash = ((hash << 5) - hash) + chr;
      hash |= 0;
    }
    id = 'bid_' + Math.abs(hash).toString(36) + '_' + Date.now().toString(36);
    localStorage.setItem('comment_browser_id', id);
    return id;
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function formatDate(dateStr: string): string {
    const d = new Date(dateStr + (dateStr.includes('Z') ? '' : 'Z'));
    const now = new Date();
    const diff = now.getTime() - d.getTime();
    const mins = Math.floor(diff / 60000);
    if (mins < 1) return '刚刚';
    if (mins < 60) return mins + ' 分钟前';
    const hours = Math.floor(mins / 60);
    if (hours < 24) return hours + ' 小时前';
    const days = Math.floor(hours / 24);
    if (days < 30) return days + ' 天前';
    return d.getFullYear() + '-' + String(d.getMonth() + 1).padStart(2, '0') + '-' + String(d.getDate()).padStart(2, '0');
  }

  async function loadComments() {
    const list = document.getElementById('comment-list')!;
    try {
      const res = await fetch('/api/comments?slug=' + encodeURIComponent(slug));
      if (!res.ok) throw new Error('加载失败');
      const comments = await res.json();
      const myId = localStorage.getItem('comment_browser_id') || '';
      if (!comments.length) {
        list.innerHTML = '<div class="comment-empty">暂无评论，来抢沙发吧~</div>';
        return;
      }
      list.innerHTML = comments.map((c: any) => {
        const isMine = c.browser_id && c.browser_id === myId;
        const badge = isMine ? '<span class="comment-badge">我</span>' : '';
        return `
        <div class="comment-item">
          <div class="comment-item-header">
            <div class="comment-avatar">${escapeHtml(c.nickname.charAt(0).toUpperCase())}</div>
            <span class="comment-nickname">${escapeHtml(c.nickname)}</span>${badge}
            <span class="comment-time">${formatDate(c.created_at)}</span>
          </div>
          <div class="comment-body">${escapeHtml(c.content)}</div>
        </div>`;
      }).join('');
    } catch {
      list.innerHTML = '<div class="comment-empty">评论加载失败</div>';
    }
  }

  async function submitComment() {
    const nicknameEl = document.getElementById('comment-nickname') as HTMLInputElement;
    const emailEl = document.getElementById('comment-email') as HTMLInputElement;
    const contentEl = document.getElementById('comment-content') as HTMLTextAreaElement;
    const btn = document.getElementById('comment-submit') as HTMLButtonElement;
    const status = document.getElementById('comment-status')!;

    const nickname = nicknameEl.value.trim();
    const email = emailEl.value.trim();
    const content = contentEl.value.trim();
    if (!nickname) { status.textContent = '请输入昵称'; status.style.color = '#c00'; return; }
    if (!content) { status.textContent = '请输入内容'; status.style.color = '#c00'; return; }

    btn.disabled = true;
    status.textContent = '发送中...';
    status.style.color = '#999';

    try {
      const res = await fetch('/api/comments', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          slug, nickname, email,
          browser_id: getBrowserId(),
          content
        }),
      });
      const data = await res.json();
      if (!res.ok) throw new Error(data.error || '发送失败');
      contentEl.value = '';
      status.textContent = '发送成功！';
      status.style.color = '#090';
      localStorage.setItem('comment_nickname', nickname);
      if (email) localStorage.setItem('comment_email', email);
      loadComments();
    } catch (e: any) {
      status.textContent = e.message;
      status.style.color = '#c00';
    } finally {
      btn.disabled = false;
      setTimeout(() => { status.textContent = ''; }, 3000);
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    const savedNick = localStorage.getItem('comment_nickname');
    const savedEmail = localStorage.getItem('comment_email');
    if (savedNick) (document.getElementById('comment-nickname') as HTMLInputElement).value = savedNick;
    if (savedEmail) (document.getElementById('comment-email') as HTMLInputElement).value = savedEmail;
    // Init browser ID
    getBrowserId();
    loadComments();
    document.getElementById('comment-submit')?.addEventListener('click', submitComment);
    document.getElementById('comment-content')?.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) submitComment();
    });
  });
</script>
