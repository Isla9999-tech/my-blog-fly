---
import type { Language, PostHeading } from '@src/types';
import { theme } from '@src/theme';
import { is_post } from '@src/utils';
import CardAuthor from './card_author.astro';
import CardAnnouncement from './card_announcement.astro';
import CardPostToc from './card_post_toc.astro';

interface Props { lang: Language; postHeadings?: PostHeading[]; }
const { lang, postHeadings } = Astro.props;
const isPost = is_post(Astro.url);
const showToc = isPost && theme.toc.post;
---

<div id="aside-content" class="aside-content w-[26%] max-[900px]:mt-5 max-[900px]:w-full">
    <CardAuthor lang={lang}/>
    <CardAnnouncement lang={lang}/>
    <div class="sticky_layout transition-[top] duration-300 min-[900px]:sticky min-[900px]:top-[15px]">
      {showToc && <CardPostToc lang={lang} postHeadings={postHeadings}/>}
    </div>
</div>
