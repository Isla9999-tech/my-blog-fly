---
import { is_post, is_home } from '@src/utils';
import { theme } from '@src/theme';

const isPost = is_post(Astro.url);
const isHome = is_home(Astro.url);

const showToc = isPost && theme.toc.post;
---

<script is:inline id="config-diff" define:vars={{isPost,isHome,showToc}}>
  window.GLOBAL_CONFIG_SITE = {
    isPost: isPost,
    isHome: isHome,
    isHighlightShrink: 'undefined',
    isToc: showToc,
  };
</script>
