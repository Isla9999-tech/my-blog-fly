---
import type { Language } from '@src/types';
import { useTranslations } from '@src/utils';

interface Props {
  lang: Language;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const pagefindTranslations = {
  placeholder: t('search.pagefind.placeholder'),
  clear_search: t('search.pagefind.clear_search'),
  load_more: t('search.pagefind.load_more'),
  search_label: t('search.pagefind.search_label'),
  filters_label: t('search.pagefind.filters_label'),
  zero_results: t('search.pagefind.zero_results'),
  many_results: t('search.pagefind.many_results'),
  one_result: t('search.pagefind.one_result'),
  alt_search: t('search.pagefind.alt_search'),
  search_suggestion: t('search.pagefind.search_suggestion'),
  searching: t('search.pagefind.searching'),
};

const loadFailedText = t('search.pagefind.load_failed');
---

<div id="search" class="hidden">
  <div id="search-mask"></div>
  <div id="local-search" class="search-dialog">
    <div class="search-nav">
      <span class="search-dialog-title">{t('search.title')}</span>
      <span class="search-close-button">
        <i class="fas fa-times"></i>
      </span>
    </div>
    <hr />
    <div id="pagefind-container"></div>
  </div>
</div>

<link rel="stylesheet" href="/pagefind/pagefind-ui.css">

<script is:inline define:vars={{ pagefindTranslations, loadFailedText }}>
  let pagefindUI = null;
  let pagefindLoaded = false;
  let isInitializing = false;

  async function loadPagefindScript() {
    if (pagefindLoaded) return Promise.resolve();

    return new Promise((resolve, reject) => {
      if (document.querySelector('script[data-pagefind-ui]')) {
        resolve();
        return;
      }

      const script = document.createElement('script');
      script.src = '/pagefind/pagefind-ui.js';
      script.type = 'text/javascript';
      script.setAttribute('data-pagefind-ui', 'true');
      script.onload = () => {
        pagefindLoaded = true;
        resolve();
      };
      script.onerror = () => reject(new Error('Failed to load Pagefind UI'));
      document.head.appendChild(script);
    });
  }

  async function initPagefind() {
    if (pagefindUI || isInitializing) return;
    isInitializing = true;

    try {
      await loadPagefindScript();

      const PagefindUIConstructor = window.PagefindUI;

      if (!PagefindUIConstructor) {
        throw new Error('PagefindUI not found on window object');
      }

      const container = document.getElementById('pagefind-container');
      if (container) {
        container.innerHTML = '';
      }

      pagefindUI = new PagefindUIConstructor({
        element: '#pagefind-container',
        showImages: false,
        excerptLength: 15,
        showSubResults: true,
        resetStyles: false,
        bundlePath: '/pagefind/',
        translations: pagefindTranslations,
      });

      setTimeout(() => {
        const pagefindInput = document.querySelector('.pagefind-ui__search-input');
        if (pagefindInput) {
          pagefindInput.focus();
        }
      }, 100);

    } catch (error) {
      console.error('Failed to load Pagefind:', error);
      const container = document.getElementById('pagefind-container');
      if (container) {
        container.innerHTML = `<p style="text-align: center; padding: 40px 20px; color: #666;">${loadFailedText}</p>`;
      }
    } finally {
      isInitializing = false;
    }
  }

  const searchButton = document.getElementById('search-button');
  const searchMask = document.getElementById('search-mask');
  const searchClose = document.querySelector('.search-close-button');
  const searchContainer = document.getElementById('search');

  function openSearch() {
    searchContainer?.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    initPagefind();
  }

  function closeSearch() {
    searchContainer?.classList.add('hidden');
    document.body.style.overflow = '';
  }

  searchButton?.addEventListener('click', openSearch);
  searchMask?.addEventListener('click', closeSearch);
  searchClose?.addEventListener('click', closeSearch);

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape' && !searchContainer?.classList.contains('hidden')) {
      closeSearch();
    }
  });
</script>

<style>
  #search {
    position: fixed;
    inset: 0;
    z-index: 1000;
  }
  #search.hidden {
    display: none;
  }

  #pagefind-container {
    width: 100%;
  }
</style>
