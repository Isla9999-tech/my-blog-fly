---
import type { Language } from '@src/types';
import Layout from '@src/layout/layout.astro';
import { getCategoryList } from '@src/prework';
import { useTranslations } from '@src/utils';

export async function getStaticPaths() {
  const languages = ['en', 'zh-CN'];
  return languages.map(lang => ({
    params: { lang },
  }));
}
const { lang } = Astro.params as { lang: Language };
const t = useTranslations(lang);
const page = {
  "title": t('page.category'),
  "type": "categories",
  "comments": false
}
const categories = await getCategoryList(lang);
---
<Layout lang={lang} page={page}>
  <div id="page">
      <div class="category-lists">
        <ul class="category-list">
          {categories.map((category) => (
            <li class="category-list-item">
              <a class="category-list-link" href={category.path}>{category.name}</a>
              <span class="category-list-count">{category.count}</span>
            </li>
          ))}
        </ul>
      </div>
  </div>
</Layout>
